<?xml version="1.0" encoding="utf-8"?>
<!-- CHIP URDF - Automatically generated and adapted for conveyorbelt_gazebo package -->
<robot name="chip">
  <link name="base_link_chip">
    <!-- Spin fix WITHOUT changing belt behaviour: the chip spun wildly on lift
         because its CAD-exported rotational inertia (~1e-6) is far too small for
         ODE once it is rigidly link-attached to the heavy SCARA tool link
         (ill-conditioned mass matrix -> rotational blow-up). Raising ONLY the
         inertia (~1e-4) damps that rotation. Mass is kept at the original 5.5 g
         so the conveyor friction dynamics are unchanged -> the chip still rides
         belt2 to the sonar instead of being flung across the cell. -->
    <inertial>
      <origin xyz="0 0 0.00225" rpy="0 0 0" />
      <mass value="0.0055" />
      <inertia
        ixx="1.0E-04"
        ixy="0.0"
        ixz="0.0"
        iyy="1.0E-04"
        iyz="0.0"
        izz="1.0E-04" />
    </inertial>
    <visual>
      <origin xyz="-2.9300 -4.3990 -6.4985" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://conveyorbelt_gazebo/meshes/chip/base_link_chip.STL" scale="5.0 5.0 5.0" />
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-2.9300 -4.3990 -6.4985" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://conveyorbelt_gazebo/meshes/chip/base_link_chip.STL" scale="5.0 5.0 5.0" />
      </geometry>
      <surface>
        <contact>
          <collide_without_contact>false</collide_without_contact>
        </contact>
      </surface>
    </collision>
  </link>

  <gazebo reference="base_link_chip">
    <material>Gazebo/Grey</material>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <selfCollide>false</selfCollide>
  </gazebo>

</robot>
